# ── Server ───────────────────────────────────────────────
#
# Copy to .env (local dev), .env.staging, or .env.production
# and fill in real values. These files are git-ignored.
#

# Runtime
# APP_ENV: development | staging | production
APP_ENV=development
NODE_ENV=development
PORT=3001

# MongoDB Atlas — use a DIFFERENT database per environment
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<database>?retryWrites=true&w=majority

# JWT — use DIFFERENT secrets per environment
JWT_SECRET=<generate-a-long-random-secret>
JWT_REFRESH_SECRET=<generate-a-long-random-secret>
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS — must match the URL the browser uses to reach the client
#   Local dev / staging local:  http://localhost:5173
#   Production:                 http://129.212.199.25
CLIENT_URL=http://localhost:5173

# Monitoring
# APP_RELEASE is usually injected by deploy workflows.
APP_RELEASE=
SLOW_REQUEST_THRESHOLD_MS=1000
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0

# Stockfish engine binary
#   Windows:  C:/Program Files/stockfish/stockfish-windows-x86-64-avx2.exe
#   Linux:    /usr/games/stockfish
STOCKFISH_PATH=C:/Program Files/stockfish/stockfish-windows-x86-64-avx2.exe
