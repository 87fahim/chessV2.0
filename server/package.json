{
  "name": "chessv2-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:staging": "cross-env APP_ENV=staging NODE_ENV=development tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "start:staging": "cross-env APP_ENV=staging NODE_ENV=production node dist/server.js",
    "start:prod": "cross-env APP_ENV=production NODE_ENV=production node dist/server.js",
    "lint": "eslint src/"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "chess.js": "^1.4.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "ffmpeg-static": "^5.3.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.15.1",
    "socket.io": "^4.8.0",
    "uuid": "^11.1.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^24.12.2",
    "@types/uuid": "^10.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.2.0",
    "globals": "^17.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.58.2"
  }
}
