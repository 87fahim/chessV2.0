# Runtime
APP_ENV=production
NODE_ENV=production
PORT=3001

# Database
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<production-db>?retryWrites=true&w=majority

# JWT
JWT_SECRET=replace-with-production-secret
JWT_REFRESH_SECRET=replace-with-production-refresh-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Client
CLIENT_URL=https://your-domain.com

# Engine
STOCKFISH_PATH=C:/Program Files/stockfish/stockfish-windows-x86-64-avx2.exe